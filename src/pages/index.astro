---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Origin from '../components/Origin.astro';
import Deployment from '../components/Deployment.astro';
import TheTurn from '../components/TheTurn.astro';
import CrashLanding from '../components/CrashLanding.astro';
import ClearingWreckage from '../components/ClearingWreckage.astro';
import Phoenix from '../components/Phoenix.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const layoutEntry = await getEntry('pages', 'layout');
const sections = (layoutEntry?.data.sections as { id: string; label: string; enabled: boolean }[]) ?? [];

const componentMap: Record<string, (_props: Record<string, never>) => any> = {
  origin: Origin,
  deployment: Deployment,
  theturn: TheTurn,
  crashlanding: CrashLanding,
  clearingwreckage: ClearingWreckage,
  phoenix: Phoenix,
};
---
<Base
  title="Sage J Phoenix | USAF Wingwoman"
  description="U.S. Air Force Flight Officer. Mission Crew Commander. EC-130H Compass Call. Reborn as Sage J Phoenix."
>
  <main>
    <Hero />
    {sections
      .filter(s => s.enabled)
      .map(s => {
        const Component = componentMap[s.id];
        return (
          <>
            {s.id === 'phoenix' && (
              <section class="image-break" aria-hidden="true">
                <div class="image-break__overlay"></div>
              </section>
            )}
            {Component ? <Component /> : null}
          </>
        );
      })
    }
  </main>
  <Footer />
</Base>

<style>
.image-break {
  position: relative;
  width: 100%;
  height: 70vh;
  background-image: url('/Images/phoenix-fire-wings.png');
  background-size: cover;
  background-position: center;
  overflow: hidden;
}
.image-break__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
}
@media (max-width: 768px) {
  .image-break { height: 50vh; }
}
</style>
