---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Origin from '../components/Origin.astro';
import Deployment from '../components/Deployment.astro';
import TheTurn from '../components/TheTurn.astro';
import CrashLanding from '../components/CrashLanding.astro';
import ClearingWreckage from '../components/ClearingWreckage.astro';
import Phoenix from '../components/Phoenix.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const layoutEntry = await getEntry('pages', 'layout');
const sections = (layoutEntry?.data.sections as { id: string; label: string; enabled: boolean }[]) ?? [];

const componentMap: Record<string, (_props: Record<string, never>) => any> = {
  origin: Origin,
  deployment: Deployment,
  theturn: TheTurn,
  crashlanding: CrashLanding,
  clearingwreckage: ClearingWreckage,
  phoenix: Phoenix,
};
---
<Base
  title="Sage J Phoenix | USAF Wingwoman"
  description="U.S. Air Force Combat Veteran. Mission Crew Commander. EC-130H Compass Call. Operation Iraqi Freedom. Reborn as Sage J Phoenix."
>
  <main>
    <Hero />
    {sections
      .filter(s => s.enabled)
      .map(s => {
        const Component = componentMap[s.id];
        return Component ? <Component /> : null;
      })
    }
  </main>
  <Footer />
</Base>
