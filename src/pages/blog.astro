---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allStories = await getCollection('stories', ({ data }) => !data.draft);
const stories = allStories.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base
  title="Stories | Sage J Phoenix"
  description="Writing from Sage J Phoenix — USAF veteran, Mission Crew Commander, and the woman who came after."
>
  <section class="blog">
    <div class="container">
      <div class="blog__header reveal">
        <p class="overline">Stories</p>
        <hr class="fire-rule" />
        <h1 class="display blog__heading">Field Notes</h1>
        <p class="blog__sub">Writing from the woman who came after.</p>
      </div>
      <ul class="blog__list">
        {stories.map((story, i) => (
          <li class="blog__item reveal" style={`transition-delay: ${i * 80}ms`}>
            <a href={`/stories/${story.slug}`} class="blog__link">
              <time class="blog__date" datetime={story.data.date.toISOString()}>
                {formatDate(story.data.date)}
              </time>
              <h2 class="blog__title">{story.data.title}</h2>
              {story.data.description && (
                <p class="blog__desc">{story.data.description}</p>
              )}
              <span class="blog__read">Read →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
.blog {
  padding-top: clamp(6rem, 12vw, 10rem);
  padding-bottom: var(--section-pad);
  background: var(--ash);
  min-height: 100svh;
}
.blog__header {
  max-width: 560px;
  margin-bottom: clamp(3rem, 6vw, 5rem);
}
.blog__heading {
  font-size: clamp(2.8rem, 7vw, 5rem);
  color: var(--white);
  margin-bottom: 1rem;
}
.blog__sub {
  color: var(--slate);
  font-size: 1rem;
  font-style: italic;
  font-family: var(--font-display);
}
.blog__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  border-top: 1px solid rgba(155,127,120,0.15);
}
.blog__item {
  border-bottom: 1px solid rgba(155,127,120,0.15);
}
.blog__link {
  display: block;
  padding: 2.5rem 0;
  transition: background 0.2s;
}
.blog__link:hover .blog__title { color: var(--amber); }
.blog__link:hover .blog__read  { color: var(--amber); }
.blog__date {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--slate);
  margin-bottom: 0.6rem;
}
.blog__title {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 0.75rem;
  transition: color 0.2s;
}
.blog__desc {
  color: var(--bone);
  opacity: 0.7;
  font-size: 0.95rem;
  max-width: 600px;
  line-height: 1.6;
  margin-bottom: 1rem;
}
.blog__read {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--slate);
  transition: color 0.2s;
}
</style>
