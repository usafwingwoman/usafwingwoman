---
import { getEntry } from 'astro:content';
const entry = await getEntry('pages', 'phoenix_rebirth');
const d = entry!.data;
---
<section class="phoenix" id="rebirth">
  <div class="phoenix__bg" aria-hidden="true">
    <div class="phoenix__fire phoenix__fire--1"></div>
    <div class="phoenix__fire phoenix__fire--2"></div>
  </div>

  <div class={`container--wide phoenix__grid${!d.venture_url && !d.credentials?.length ? ' phoenix__grid--full' : ''}`}>
    <div class="phoenix__narrative reveal">
      <p class="overline">The Rebirth</p>
      <hr class="fire-rule" />
      <h2 class="display phoenix__heading">
        {d.heading_line1}<br/><em>{d.heading_line2}</em>
      </h2>
      <div class="phoenix__body">
        {d.body?.map((p: { text: string }) => <p set:html={p.text} />)}
        <p class="phoenix__declaration">
          {d.declaration_line1}<br/>
          <em>{d.declaration_line2}</em>
        </p>
      </div>
    </div>

    {(d.venture_url || d.credentials?.length > 0) && (
      <aside class="cred reveal">
        {d.credentials?.map((c: { label: string; value: string }) => (
          <div class="cred__item">
            <span class="cred__label">{c.label}</span>
            <span class="cred__value">{c.value}</span>
          </div>
        ))}
        {d.venture_url && (
          <div class="cred__item cred__item--link">
            <span class="cred__label">{d.venture_label}</span>
            <a href={d.venture_url} class="cred__link" target="_blank" rel="noopener">
              {d.venture_text}
            </a>
          </div>
        )}
      </aside>
    )}
  </div>
</section>

<style>
.phoenix {
  position: relative;
  padding-block: var(--section-pad);
  background: var(--ash);
  overflow: hidden;
}
.phoenix__bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.phoenix__fire {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
}
.phoenix__fire--1 {
  width: 50vw; height: 50vw;
  background: radial-gradient(circle, rgba(192,57,43,0.2) 0%, transparent 70%);
  top: -20%; right: -10%;
  animation: breathe 9s ease-in-out infinite;
}
.phoenix__fire--2 {
  width: 35vw; height: 35vw;
  background: radial-gradient(circle, rgba(232,145,58,0.15) 0%, transparent 70%);
  bottom: -10%; left: 5%;
  animation: breathe 12s ease-in-out infinite reverse 3s;
}
@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.12); opacity: 1; }
}

.phoenix__grid {
  display: grid;
  grid-template-columns: 3fr 2fr;
  gap: 4rem 5rem;
  align-items: start;
  position: relative;
  z-index: 1;
}
.phoenix__grid--full {
  grid-template-columns: 1fr;
}
.phoenix__heading {
  font-size: clamp(2.4rem, 6vw, 4.5rem);
  color: var(--white);
  margin-bottom: 2.5rem;
}
.phoenix__heading em {
  color: var(--amber);
  font-style: italic;
}
.phoenix__body {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  color: var(--bone);
  opacity: 0.85;
}
.phoenix__body strong {
  color: var(--amber);
  font-weight: 500;
}
.phoenix__declaration {
  margin-top: 1rem;
  font-family: var(--font-display);
  font-size: clamp(1.2rem, 2.5vw, 1.6rem);
  font-weight: 700;
  color: var(--white);
  line-height: 1.4;
  opacity: 1 !important;
}
.phoenix__declaration em {
  color: var(--amber);
  font-style: italic;
}

/* Credential block */
.cred {
  border-left: 2px solid var(--crimson);
  padding-left: 1.75rem;
  position: sticky;
  top: 4rem;
  align-self: start;
}
.cred__item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding-block: 1.25rem;
  border-bottom: 1px solid rgba(155,127,120,0.12);
}
.cred__item:last-child { border-bottom: none; }
.cred__label {
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
}
.cred__link {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  font-weight: 700;
  color: var(--amber);
  line-height: 1.1;
  transition: color 0.2s;
}
.cred__link:hover { color: var(--flame); }

@media (max-width: 768px) {
  .phoenix__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .cred {
    position: static;
  }
}
</style>
