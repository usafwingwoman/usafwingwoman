---
const stats = [
  { value: '9', label: 'Crew members supervised airborne' },
  { value: 'Top Secret', label: 'Clearance level held & managed' },
  { value: 'EC-130H', label: 'Compass Call — classified EA platform' },
  { value: '2005', label: 'Deployed — Operation Iraqi Freedom' },
  { value: '5', label: 'Airmen led as Chief of Security' },
  { value: 'Dual-Qualified', label: 'Only one on the airframe during deployment' },
];
---
<section class="stats" id="service">
  <div class="container--wide">
    <p class="overline stats__overline reveal">By the numbers</p>
    <div class="stats__grid">
      {stats.map((s, i) => (
        <div class={`stats__card reveal`} style={`transition-delay: ${i * 80}ms`}>
          <div class="stats__value">{s.value}</div>
          <div class="stats__label">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.stats {
  padding-block: var(--section-pad);
  background: var(--ember);
  border-top: 1px solid rgba(192,57,43,0.2);
  border-bottom: 1px solid rgba(192,57,43,0.2);
}
.stats__overline {
  text-align: center;
  margin-bottom: 3rem;
}
.stats__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1px;
  background: rgba(192,57,43,0.15);
}
.stats__card {
  background: var(--ember);
  padding: 2.5rem 2rem;
  position: relative;
  transition: background 0.3s ease;
}
.stats__card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 2rem;
  width: 0;
  height: 1px;
  background: linear-gradient(90deg, var(--fire), var(--amber));
  transition: width 0.5s ease;
}
.stats__card:hover::after { width: calc(100% - 4rem); }
.stats__card:hover { background: rgba(30,21,18,0.8); }

.stats__value {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3.5vw, 2.6rem);
  font-weight: 900;
  color: var(--amber);
  line-height: 1;
  margin-bottom: 0.75rem;
}
.stats__label {
  font-size: 0.8rem;
  letter-spacing: 0.05em;
  color: var(--slate);
  line-height: 1.4;
}
</style>
