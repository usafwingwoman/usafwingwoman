---
import { getEntry } from 'astro:content';
const entry = await getEntry('pages', 'home_hero');
const d = entry!.data;
const nameParts = (d.hero_name as string).split(' ');
const heroLast = nameParts.pop();
const heroFirst = nameParts.join(' ');
---
<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <canvas id="ember-canvas" class="hero__canvas"></canvas>
    <div class="hero__reduced-bg"></div>
    <div class="hero__grain"></div>
  </div>

  <div class="hero__content container">
    <p class="overline hero__overline">USAFWingwoman.com</p>
    <h1 class="display hero__name">{heroFirst}<br/><em>{heroLast}</em></h1>
    <p class="hero__tagline display-italic">
      {d.hero_tagline_1}<br/>{d.hero_tagline_2}
    </p>
    <div class="hero__meta">
      <span>Honorably Served · 2003–2007</span>
      <span class="hero__dot" aria-hidden="true">·</span>
      <span>U.S. Air Force Rated Officer</span>
      <span class="hero__dot" aria-hidden="true">·</span>
      <span>EC-130H Compass Call</span>
    </div>
  </div>

  <div class="hero__scroll-cue" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

/* Background */
.hero__bg {
  position: absolute;
  inset: 0;
  background: var(--ash);
}
.hero__canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

/* Shown only when prefers-reduced-motion is active */
.hero__reduced-bg {
  display: none;
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 50% 80%, rgba(139,26,26,0.3) 0%, transparent 70%);
  pointer-events: none;
}
@media (prefers-reduced-motion: reduce) {
  .hero__canvas { display: none; }
  .hero__reduced-bg { display: block; }
}

.hero__grain {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  background-size: 200px;
  opacity: 0.5;
  mix-blend-mode: overlay;
  pointer-events: none;
  z-index: 1;
}

/* Content */
.hero__content {
  position: relative;
  z-index: 2;
  padding-top: clamp(5rem, 12vw, 9rem);
}
.hero__overline {
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.3s forwards;
}
.hero__name {
  font-size: clamp(4rem, 12vw, 10rem);
  color: var(--white);
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.55s forwards;
}
.hero__name em {
  color: var(--amber);
  font-style: italic;
}
.hero__tagline {
  font-size: clamp(1.2rem, 2.5vw, 1.9rem);
  color: var(--slate);
  margin-bottom: 3rem;
  max-width: 540px;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.8s forwards;
}
.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #9a7f78;
  font-weight: 500;
  opacity: 0;
  animation: fadeUp 0.9s ease 1.05s forwards;
}
.hero__dot { color: var(--crimson); }

@media (max-width: 768px) {
  .hero__tagline { font-size: clamp(1.1rem, 4vw, 1.5rem); }
}
@media (max-width: 480px) {
  .hero__meta { font-size: 0.68rem; gap: 0.4rem 0.75rem; }
  .hero__scroll-cue { display: none; }
}

/* Scroll cue */
.hero__scroll-cue {
  position: absolute;
  bottom: 2.5rem;
  left: clamp(1.5rem, 5vw, 3rem);
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #5a4540;
  z-index: 2;
  opacity: 0;
  animation: fadeIn 1s ease 1.8s forwards;
}
.hero__scroll-line {
  width: 3rem;
  height: 1px;
  background: linear-gradient(90deg, var(--crimson), transparent);
  animation: extendLine 1.2s ease 2s forwards;
  transform-origin: left;
  transform: scaleX(0);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: none; }
}
@keyframes fadeIn {
  to { opacity: 1; }
}
@keyframes extendLine {
  to { transform: scaleX(1); }
}
</style>

<script>
(function () {
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReduced) return;

  const canvas = document.getElementById('ember-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const COLORS = ['#8b1a1a', '#a02020', '#c03a1a', '#e05c2a', '#d4703a', '#d4a843'];
  const isMobile = () => window.innerWidth < 768;
  const TARGET_COUNT = () => isMobile() ? 20 : 38;

  interface Ember {
    x: number;
    y: number;
    size: number;
    speed: number;
    drift: number;
    driftSpeed: number;
    driftPhase: number;
    opacity: number;
    fadeStart: number; // y fraction (0–1) at which fading begins
    color: string;
  }

  let W = 0, H = 0;
  const embers: Ember[] = [];

  function resize() {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width = W;
    canvas.height = H;
  }

  function rand(min: number, max: number) {
    return min + Math.random() * (max - min);
  }

  function spawnEmber(startFromBottom = false): Ember {
    return {
      x: rand(0, W),
      y: startFromBottom ? rand(H * 0.7, H) : rand(0, H),
      size: rand(1, 3),
      speed: rand(0.4, 1.2),
      drift: rand(-0.6, 0.6),
      driftSpeed: rand(0.003, 0.008),
      driftPhase: rand(0, Math.PI * 2),
      opacity: rand(0.5, 1),
      fadeStart: rand(0.3, 0.6),
      color: COLORS[Math.floor(Math.random() * COLORS.length)],
    };
  }

  function init() {
    resize();
    embers.length = 0;
    const count = TARGET_COUNT();
    for (let i = 0; i < count; i++) {
      embers.push(spawnEmber(false));
    }
  }

  function tick() {
    ctx.clearRect(0, 0, W, H);

    for (let i = 0; i < embers.length; i++) {
      const e = embers[i];

      // Move upward
      e.y -= e.speed;
      // Horizontal sine drift
      e.driftPhase += e.driftSpeed;
      e.x += Math.sin(e.driftPhase) * e.drift;

      // Fade as it rises — start fading at fadeStart fraction from top
      const progress = 1 - e.y / H; // 0 at bottom, 1 at top
      const fadeBegin = e.fadeStart;
      let alpha = e.opacity;
      if (progress > fadeBegin) {
        alpha = e.opacity * (1 - (progress - fadeBegin) / (1 - fadeBegin));
      }
      alpha = Math.max(0, alpha);

      // Respawn when it leaves the top or fades out completely
      if (e.y < -10 || alpha <= 0) {
        embers[i] = spawnEmber(true);
        continue;
      }

      // Draw ember as a soft glowing dot
      const grad = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.size * 2);
      grad.addColorStop(0, e.color);
      grad.addColorStop(1, 'transparent');

      ctx.globalAlpha = alpha;
      ctx.beginPath();
      ctx.arc(e.x, e.y, e.size * 2, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      // Bright core
      ctx.globalAlpha = alpha * 0.9;
      ctx.beginPath();
      ctx.arc(e.x, e.y, e.size * 0.5, 0, Math.PI * 2);
      ctx.fillStyle = '#fff8e0';
      ctx.fill();
    }

    ctx.globalAlpha = 1;

    // Maintain target count
    while (embers.length < TARGET_COUNT()) {
      embers.push(spawnEmber(true));
    }

    raf = requestAnimationFrame(tick);
  }

  let raf: number;
  let resizeTimer: ReturnType<typeof setTimeout>;

  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      cancelAnimationFrame(raf);
      init();
      tick();
    }, 150);
  });

  init();
  tick();
})();
</script>
