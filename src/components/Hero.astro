---
---
<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__glow hero__glow--1"></div>
    <div class="hero__glow hero__glow--2"></div>
    <div class="hero__glow hero__glow--3"></div>
    <div class="hero__grain"></div>
  </div>

  <div class="hero__content container">
    <p class="overline hero__overline">USAFWingwoman.com</p>
    <h1 class="display hero__name">Sage J<br/><em>Phoenix</em></h1>
    <p class="hero__tagline display-italic">
      From the ashes of service,<br/>a remarkable life takes flight.
    </p>
    <div class="hero__meta">
      <span>U.S. Air Force · 2003–2007</span>
      <span class="hero__dot" aria-hidden="true">·</span>
      <span>Operation Iraqi Freedom · 2005</span>
      <span class="hero__dot" aria-hidden="true">·</span>
      <span>EC-130H Compass Call</span>
    </div>
  </div>

  <div class="hero__scroll-cue" aria-hidden="true">
    <span>Scroll</span>
    <div class="hero__scroll-line"></div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

/* Background atmosphere */
.hero__bg {
  position: absolute;
  inset: 0;
  background: var(--ash);
}
.hero__glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
}
.hero__glow--1 {
  width: 55vw; height: 55vw;
  background: radial-gradient(circle, rgba(192,57,43,0.25) 0%, transparent 70%);
  top: -15%; right: -10%;
  animation: pulse 8s ease-in-out infinite;
}
.hero__glow--2 {
  width: 40vw; height: 40vw;
  background: radial-gradient(circle, rgba(232,145,58,0.18) 0%, transparent 70%);
  bottom: 5%; left: -5%;
  animation: pulse 11s ease-in-out infinite reverse;
}
.hero__glow--3 {
  width: 30vw; height: 30vw;
  background: radial-gradient(circle, rgba(139,26,26,0.3) 0%, transparent 70%);
  top: 40%; left: 30%;
  animation: pulse 14s ease-in-out infinite 2s;
}
.hero__grain {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  background-size: 200px;
  opacity: 0.5;
  mix-blend-mode: overlay;
  pointer-events: none;
}

@keyframes pulse {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.08); }
}

/* Content */
.hero__content {
  position: relative;
  z-index: 1;
  padding-top: clamp(5rem, 12vw, 9rem);
}
.hero__overline {
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.3s forwards;
}
.hero__name {
  font-size: clamp(4rem, 12vw, 10rem);
  color: var(--white);
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.55s forwards;
}
.hero__name em {
  color: var(--amber);
  font-style: italic;
}
.hero__tagline {
  font-size: clamp(1.2rem, 2.5vw, 1.9rem);
  color: var(--slate);
  margin-bottom: 3rem;
  max-width: 540px;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.8s forwards;
}
.hero__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #9a7f78;
  font-weight: 500;
  opacity: 0;
  animation: fadeUp 0.9s ease 1.05s forwards;
}
.hero__dot { color: var(--crimson); }

@media (max-width: 768px) {
  .hero__tagline { font-size: clamp(1.1rem, 4vw, 1.5rem); }
}
@media (max-width: 480px) {
  .hero__meta { font-size: 0.68rem; gap: 0.4rem 0.75rem; }
  .hero__scroll-cue { display: none; }
}

/* Scroll cue */
.hero__scroll-cue {
  position: absolute;
  bottom: 2.5rem;
  left: clamp(1.5rem, 5vw, 3rem);
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--smoke);
  color: #5a4540;
  opacity: 0;
  animation: fadeIn 1s ease 1.8s forwards;
}
.hero__scroll-line {
  width: 3rem;
  height: 1px;
  background: linear-gradient(90deg, var(--crimson), transparent);
  animation: extendLine 1.2s ease 2s forwards;
  transform-origin: left;
  transform: scaleX(0);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: none; }
}
@keyframes fadeIn {
  to { opacity: 1; }
}
@keyframes extendLine {
  to { transform: scaleX(1); }
}
</style>
