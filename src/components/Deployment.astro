---
import { getEntry } from 'astro:content';
const entry = await getEntry('pages', 'deployment');
const d = entry!.data;
---
<section class="deploy" id="deployment">
  <div class="deploy__bg" aria-hidden="true"></div>
  <div class="container--wide deploy__grid">
    <div class="deploy__narrative reveal">
      <p class="overline">Severe Turbulence Ahead</p>
      <hr class="fire-rule" />
      <h2 class="display deploy__heading">
        {d.heading_line1}<br/>{d.heading_line2}<br/><em>{d.heading_line3}</em>
      </h2>
      <div class="deploy__body">
        {d.body?.map((p: { text: string }) => <p set:html={p.text} />)}
        <blockquote class="deploy__quote">
          <p>"{d.blockquote}"</p>
        </blockquote>
      </div>
    </div>

    <aside class="cred reveal">
      {d.credentials?.map((c) => (
        <div class="cred__item">
          <span class="cred__label">{c.label}</span>
          <span class="cred__value">{c.value}</span>
        </div>
      ))}
    </aside>
  </div>
</section>

<style>
.deploy {
  position: relative;
  padding-block: var(--section-pad);
  background: var(--coal);
  overflow: hidden;
}
.deploy__bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 80% at 90% 50%, rgba(139,26,26,0.15) 0%, transparent 70%);
  pointer-events: none;
}
.deploy__grid {
  display: grid;
  grid-template-columns: 3fr 2fr;
  gap: 4rem 5rem;
  align-items: start;
  position: relative;
  z-index: 1;
}
.deploy__heading {
  font-size: clamp(2.4rem, 5.5vw, 4rem);
  color: var(--white);
  margin-bottom: 2.5rem;
  margin-top: 1rem;
}
.deploy__heading em {
  color: var(--amber);
  font-style: italic;
}
.deploy__body {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  color: var(--bone);
  opacity: 0.85;
}
.deploy__body strong {
  color: var(--amber);
  font-weight: 500;
}
.deploy__quote {
  border-left: 2px solid var(--crimson);
  padding-left: 1.5rem;
  margin-top: 1rem;
}
.deploy__quote p {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.05rem;
  color: var(--slate);
  line-height: 1.6;
}

/* Credential block */
.cred {
  border-left: 2px solid var(--crimson);
  padding-left: 1.75rem;
  position: sticky;
  top: 4rem;
  align-self: start;
}
.cred__item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding-block: 1.25rem;
  border-bottom: 1px solid rgba(155,127,120,0.12);
}
.cred__item:last-child { border-bottom: none; }
.cred__label {
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
}
.cred__value {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  font-weight: 700;
  color: var(--amber);
  line-height: 1.1;
}

@media (max-width: 768px) {
  .deploy__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .cred {
    position: static;
  }
}
</style>
