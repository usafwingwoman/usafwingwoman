---
import { getEntry } from 'astro:content';
const entry = await getEntry('pages', 'origin');
const d = entry!.data;
---
<section class="origin" id="origin">
  <div class="container--wide">
    <div class="origin__grid">
      <div class="origin__narrative reveal">
        <p class="overline">The Origin</p>
        <hr class="fire-rule" />
        <h2 class="display origin__heading">
          {d.heading_line1}<br/><em>{d.heading_line2}</em>
        </h2>
        <div class="origin__body">
          {d.body?.map((p: { text: string }) => <p set:html={p.text} />)}
        </div>
      </div>

      <aside class="cred reveal">
        {d.credentials?.map((c) => (
          <div class="cred__item">
            <span class="cred__label">{c.label}</span>
            <span class="cred__value">{c.value}</span>
          </div>
        ))}
      </aside>
    </div>
  </div>
</section>

<style>
.origin {
  padding-block: var(--section-pad);
  background: linear-gradient(180deg, var(--ash) 0%, var(--coal) 100%);
}
.origin__grid {
  display: grid;
  grid-template-columns: 3fr 2fr;
  gap: 4rem 5rem;
  align-items: start;
}
.origin__heading {
  font-size: clamp(2.4rem, 6vw, 4.5rem);
  color: var(--white);
  margin-bottom: 2.5rem;
}
.origin__heading em {
  color: var(--amber);
  font-style: italic;
}
.origin__body {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  color: var(--bone);
  opacity: 0.85;
}
.origin__body strong {
  color: var(--amber);
  font-weight: 500;
}

/* Credential block */
.cred {
  border-left: 2px solid var(--crimson);
  padding-left: 1.75rem;
  position: sticky;
  top: 4rem;
  align-self: start;
}
.cred__item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding-block: 1.25rem;
  border-bottom: 1px solid rgba(155,127,120,0.12);
}
.cred__item:last-child { border-bottom: none; }
.cred__label {
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
}
.cred__value {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  font-weight: 700;
  color: var(--amber);
  line-height: 1.1;
}

@media (max-width: 768px) {
  .origin__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .cred {
    position: static;
  }
}
</style>
