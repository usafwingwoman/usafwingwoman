---
import { getEntry } from 'astro:content';
const entry = await getEntry('pages', 'clearing_wreckage');
const d = entry!.data;
---
<section class="wreckage" id="clearing-wreckage">
  <div class="container--wide">
    <div class={`wreckage__grid${!d.credentials?.length ? ' wreckage__grid--full' : ''}`}>
      <div class="wreckage__narrative reveal">
        <p class="overline">Clearing the Wreckage</p>
        <hr class="fire-rule" />
        <h2 class="display wreckage__heading">
          {d.heading_line1}<br/><em>{d.heading_line2}</em>
        </h2>
        <div class="wreckage__body">
          {d.body?.map((p: { text: string }) => <p set:html={p.text} />)}
        </div>
      </div>

      {d.credentials?.length > 0 && (
        <aside class="cred reveal">
          {d.credentials.map((c: { label: string; value: string }) => (
            <div class="cred__item">
              <span class="cred__label">{c.label}</span>
              <span class="cred__value">{c.value}</span>
            </div>
          ))}
        </aside>
      )}
    </div>
  </div>
</section>

<style>
.wreckage {
  padding-block: var(--section-pad);
  background: linear-gradient(180deg, var(--coal) 0%, var(--ash) 100%);
  position: relative;
}
.wreckage::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--crimson), transparent);
}
.wreckage__grid {
  display: grid;
  grid-template-columns: 3fr 2fr;
  gap: 4rem 5rem;
  align-items: start;
}
.wreckage__grid--full {
  grid-template-columns: 1fr;
}
.wreckage__heading {
  font-size: clamp(2.4rem, 6vw, 4.5rem);
  color: var(--white);
  margin-bottom: 2.5rem;
}
.wreckage__heading em {
  color: var(--amber);
  font-style: italic;
}
.wreckage__body {
  display: flex;
  flex-direction: column;
  gap: 1.4rem;
  color: var(--bone);
  opacity: 0.85;
}
.wreckage__body p { margin: 0; }
.wreckage__body em { color: var(--amber); font-style: italic; }
.wreckage__body strong { color: var(--amber); font-weight: 500; }
.drop-quote {
  display: block;
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 700;
  line-height: 1.2;
  color: var(--flame);
  opacity: 1 !important;
}
.drop-quote--sm {
  font-size: clamp(1.3rem, 2.5vw, 2rem);
}
.drop-quote--amber {
  color: var(--amber);
}

.cred {
  border-left: 2px solid var(--crimson);
  padding-left: 1.75rem;
  position: sticky;
  top: 4rem;
  align-self: start;
}
.cred__item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding-block: 1.25rem;
  border-bottom: 1px solid rgba(155,127,120,0.12);
}
.cred__item:last-child { border-bottom: none; }
.cred__label {
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
}
.cred__value {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  font-weight: 700;
  color: var(--amber);
  line-height: 1.1;
}

@media (max-width: 768px) {
  .wreckage__grid {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .cred { position: static; }
}
</style>
