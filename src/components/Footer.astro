---
import { getEntry } from 'astro:content';
const entry = await getEntry('pages', 'footer');
const d = entry!.data;
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer__line" aria-hidden="true"></div>
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__name">{d.name}</p>
      <p class="footer__sub overline">{d.sub}</p>
    </div>
    <div class="footer__links">
      <a href={d.aeryon_url} class="footer__link" target="_blank" rel="noopener">
        {d.aeryon_label}
      </a>
    </div>
    <p class="footer__copy">
      © {year} · {d.copyright}
    </p>
  </div>
</footer>

<style>
.footer {
  background: var(--coal);
  padding-block: 3rem 3rem;
}
.footer__line {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--crimson), var(--amber), transparent);
  margin-bottom: 4rem;
  opacity: 0.4;
}
.footer__inner {
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: auto auto;
  gap: 0.5rem 3rem;
  align-items: center;
}
@media (max-width: 480px) {
  .footer__inner { grid-template-columns: 1fr; }
  .footer__links { text-align: left; }
}
.footer__brand { grid-column: 1; grid-row: 1; }
.footer__links { grid-column: 2; grid-row: 1; text-align: right; }
.footer__copy  { grid-column: 1 / -1; }

.footer__name {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--amber);
}
.footer__sub {
  margin-top: 0.15rem;
  color: var(--slate);
}
.footer__link {
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--slate);
  transition: color 0.2s;
}
.footer__link:hover { color: var(--amber); }
.footer__copy {
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--slate);
  margin-top: 3rem;
}
</style>
